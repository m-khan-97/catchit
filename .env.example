# Supabase — from Project Settings > API in the Supabase dashboard.
# NEXT_PUBLIC_* vars are sent to the browser: only put the anon key here,
# never the service role key.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key — server-only, bypasses Row Level Security entirely.
# Used by src/lib/supabase/admin.ts (cron/discovery route only). Never
# expose this to the client or commit it.
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic API key for the discovery pipeline's web_search calls.
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Shared secret Vercel Cron sends as `Authorization: Bearer <value>` when it
# triggers /api/cron/discover. Generate with: openssl rand -hex 32
CRON_SECRET=

# Discord incoming webhook URL — posts an embed when an admin approves an
# opportunity. Server Settings > Integrations > Webhooks.
DISCORD_WEBHOOK_URL=

# Resend (https://resend.com) — sends digest confirmation + weekly digest
# emails. DIGEST_FROM_EMAIL must be on a domain you've verified in Resend
# (SPF/DKIM), e.g. "CatchIt <digest@yourdomain>". In development, leaving
# these blank logs emails to the console instead of sending.
RESEND_API_KEY=
DIGEST_FROM_EMAIL=

# Umami Cloud (https://cloud.umami.is) website ID for privacy-friendly
# analytics. Leave blank to skip loading the tracking script entirely
# (e.g. in local development).
NEXT_PUBLIC_UMAMI_WEBSITE_ID=

# Sentry (https://sentry.io) error tracking — server + edge (SENTRY_DSN) and
# browser (NEXT_PUBLIC_SENTRY_DSN) can use the same DSN from one Sentry
# project. Leave both blank to skip Sentry entirely (no account needed).
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# Public site URL, used to build absolute links in the calendar feed, OG
# tags, and sitemap. No trailing slash.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
